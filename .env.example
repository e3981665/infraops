# Development-only defaults for the Docker Compose demo stack.
# These are intentionally fake local/demo values for seeded portfolio workflows.
# Replace all passwords and signing keys before using any non-local environment.

POSTGRES_DB=infraops
POSTGRES_USER=infraops
POSTGRES_PASSWORD=infraops_demo_only
POSTGRES_PORT=5432

API_PORT=8080
FRONTEND_PORT=5173

INFRAOPS_JWT_SIGNING_KEY=LOCAL_DEVELOPMENT_SIGNING_KEY_REPLACE_ME_DEMO_ONLY
INFRAOPS_ADMIN_FULL_NAME=InfraOps Administrator
INFRAOPS_ADMIN_EMAIL=admin@infraops.local
INFRAOPS_ADMIN_PASSWORD=DemoOnly-Admin-Local
# Optional: use pt-BR before first seed to create Portuguese demo business labels.
INFRAOPS_DEMO_CONTENT_LOCALE=en-US
